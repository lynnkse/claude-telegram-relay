# Irina's AutoCAD Bot — session-specific config
# Overrides values from .env for the second session instance.
# Source after .env: set -a; source .env; source irina.env; set +a

TELEGRAM_BOT_TOKEN=8269464332:AAHS_yb00D_b6IDtnSzJUQOVU76lNvjEDSU
TELEGRAM_USER_ID=1429620448
TELEGRAM_EXTRA_USER_IDS=310065542

USER_NAME=Irina
USER_TIMEZONE=Europe/Moscow

# Separate socket dir so both sessions run in parallel without colliding
SOCKET_DIR=/tmp/cognitive-hq-irina

# Separate relay dir (lock file, session ID)
RELAY_DIR=/home/lynnkse/.claude-relay-irina

# Claude's working directory — distinct project so session JSONLs are separate
PROJECT_DIR=/home/lynnkse/autocad_project

# AutoCAD expert system prompt profile
PROFILE_PATH=/home/lynnkse/cognitive-hq/claude-telegram-relay/config/irina_profile.md

# Don't inject Lynn's personal memory into Irina's session
SKIP_MEMORY_FETCH=1

# Separate Supabase channel so Irina's messages never appear in Lynn's memory fetch
SESSION_CHANNEL=irina_autocad

# Disable proactive check-ins — Irina's bot is AutoCAD-only, no personal task tracking
PROACTIVE_ENABLED=0
